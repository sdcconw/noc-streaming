# -------------------------------
# Docker Compose 共通設定
# -------------------------------

# コンテナ再起動ポリシー
RESTART_POLICY=unless-stopped

# MySQLイメージ名
MYSQL_IMAGE="mysql:8.4"

# MySQLコンテナ名
MYSQL_CONTAINER_NAME="noc-streaming-mysql"

# MySQL公開ポート（ホスト側）
MYSQL_PORT=3306

# MySQL rootパスワード
MYSQL_ROOT_PASSWORD="rootpass"

# アプリ用MySQLデータベース名
MYSQL_DATABASE="noc_streaming"

# アプリ用MySQLユーザー名
MYSQL_USER="noc_user"

# アプリ用MySQLユーザーパスワード
MYSQL_PASSWORD="noc_pass"

# nocstreamコンテナ名
NOCSTREAM_CONTAINER_NAME="noc-streaming-nocstream"

# nocstreamコンテナの共有メモリサイズ
NOCSTREAM_SHM_SIZE="1gb"

# API公開ポート（ホスト側）
NOCSTREAM_PORT=3000

# VNC公開ポート範囲（ホスト側）
VNC_HOST_PORT_RANGE="15900-15949"

# noVNCイメージ名
NOVNC_IMAGE="theasp/novnc:latest"

# noVNCコンテナ名
NOVNC_CONTAINER_NAME="noc-streaming-novnc"

# noVNC公開ポート（ホスト側）
NOVNC_PORT=6080

# noVNC内xterm起動有無
NOVNC_RUN_XTERM=no

# noVNC内fluxbox起動有無
NOVNC_RUN_FLUXBOX=no

# noVNC表示幅
NOVNC_DISPLAY_WIDTH=1920

# noVNC表示高さ
NOVNC_DISPLAY_HEIGHT=1080

# noVNCトークン生成時の最大ジョブID
VNC_TOKEN_MAX_ID=1000

# データベースURL（Prisma接続先）
DATABASE_URL="mysql://noc_user:noc_pass@127.0.0.1:3306/noc_streaming"

# Docker Compose内のAPIコンテナ用データベースURL
DATABASE_URL_COMPOSE="mysql://noc_user:noc_pass@mysql:3306/noc_streaming"

# Web待受ポート
PORT=3000

# JWT署名鍵（必須・十分に長いランダム文字列に変更）
JWT_SECRET="change-this-secret"

# 機密情報暗号化鍵（必須・JWT_SECRETとは別のランダム文字列）
SECRET_ENCRYPTION_KEY="change-this-encryption-key"

# 認証トークン有効期限（秒）
AUTH_TOKEN_TTL_SECONDS=3600

# CookieにSecure属性を付与（HTTPS運用時はtrue）
COOKIE_SECURE=false

# ワーカーモード（real: 実処理 / mock: 疑似処理）
WORKER_MODE="real"

# ワーカー監視間隔（ミリ秒）
WORKER_MONITOR_INTERVAL_MS=5000

# 初期ローカル管理ユーザー名
ADMIN_USERNAME="admin"

# 初期ローカル管理ユーザーパスワード
ADMIN_PASSWORD="password"

# 起動ごとに初期管理ユーザーのパスワードを上書きするか
ADMIN_FORCE_RESET_PASSWORD=true

# 起動時にLDAP設定を環境変数から投入するか
LDAP_BOOTSTRAP_ENABLED=false

# LDAPサーバーURL（ldap:// または ldaps://）
LDAP_SERVER_URL="ldaps://ldap.example.local:636"

# LDAP接続用Bind DN
LDAP_BIND_DN="cn=admin,dc=example,dc=local"

# LDAP接続用Bind Password
LDAP_BIND_PASSWORD="changeme"

# LDAP検索ベースDN
LDAP_BASE_DN="dc=example,dc=local"

# LDAPユーザー検索フィルタ（{username} を必ず含める）
LDAP_USER_FILTER="(uid={username})"

# ログイン許可グループDN（空文字でグループ制限なし）
LDAP_GROUP_DN="cn=noc-admins,ou=groups,dc=example,dc=local"

# Browser入力ジョブのVNC公開を有効化するか
WORKER_VNC_ENABLED=true

# APIが返すVNC接続先ホスト名
VNC_PUBLIC_HOST="localhost"

# VNC割当開始ポート
VNC_BASE_PORT=15900

# VNCポート割当の幅（job_id % VNC_PORT_SPAN）
VNC_PORT_SPAN=50

# noVNCリンク生成を有効化するか
NOVNC_ENABLED=true

# noVNC公開ベースURL（ブラウザから到達可能なURL）
NOVNC_PUBLIC_BASE_URL="http://localhost:6080"
